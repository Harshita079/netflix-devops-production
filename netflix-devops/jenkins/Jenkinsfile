pipeline {
    agent any

    stages {

        stage('Terraform Format') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform fmt'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform plan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }
    }
}