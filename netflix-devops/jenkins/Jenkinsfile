pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Harshita079/netflix-devops-production.git'
            }
        }

        stage('Terraform Format') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform fmt'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform plan'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('netflix-devops') {
                    sh 'docker build -t netflix-app .'
                }
            }
        }

        stage('Remove Old Container') {
            steps {
                sh 'docker rm -f netflix-container || true'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d -p 80:80 --name netflix-container netflix-app'
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully!'
        }

        failure {
            echo 'Pipeline Failed!'
        }
    }
}