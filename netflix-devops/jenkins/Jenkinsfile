pipeline {
    agent any

    environment {
        TF_IN_AUTOMATION = "true"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Harshita079/netflix-devops-production.git'
            }
        }

        stage('Debug Files') {
            steps {
                sh 'pwd'
                sh 'ls -la'
                sh 'find .'
            }
        }

        stage('Terraform Format Check') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform fmt -check'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('netflix-devops/terraform') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline Successfully Executed!'
        }

        failure {
            echo 'Pipeline Failed!'
        }
    }
}