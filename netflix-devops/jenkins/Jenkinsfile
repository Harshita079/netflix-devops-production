pipeline {
    agent none

    stages {

        stage('Build') {
            agent { label 'jenkins-master' }

            steps {
                sh 'docker build -t netflix-app -f docker/Dockerfile .'
            }
        }

        stage('Deploy') {
            agent { label 'app-server' }

            steps {
                sh '''
                docker stop netflix || true
                docker rm netflix || true

                docker build -t netflix-app -f docker/Dockerfile .

                docker run -d -p 80:80 --name netflix netflix-app
                '''
            }
        }
    }
}